# Monorepo root gitignore

# Build outputs
/fruitshopp/target/
/fruitshop-ui/build/
/fruitshop-ui/node_modules/
node_modules/
target/

# IDE / Editor configurations
.idea/
.vscode/
*.iml
*.iws
*.ipr
/fruitshopp/.settings/
/fruitshopp/.project
/fruitshopp/.classpath
/fruitshopp/.factorypath
/fruitshopp/HELP.md

# Local environment and secret files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
fruitshop-ui/.env
fruitshop-ui/.env.local

# Git backups
**/.git_backup/

# Logs
*.log
startup.log
