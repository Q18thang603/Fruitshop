{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "./mvnw clean package -DskipTests"
  },
  "deploy": {
    "startCommand": "java -jar target/fruitshopp-0.0.1-SNAPSHOT.jar",
    "restartPolicyType": "ON_FAILURE"
  },
  "variables": {
    "NIXPACKS_JDK_VERSION": "21",
    "PORT": "8080"
  }
}
